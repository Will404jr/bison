// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  active       Boolean  @default(true)
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
}

model Branch {
  id           String   @id @default(cuid())
  name         String
  location     String
  username     String   @unique
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tickets      Ticket[]
  users        User[]
}

model Service {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  tellers     Teller[]
}

model Teller {
  id         String    @id @default(cuid())
  tillNumber Int       @unique
  pinHash    String?
  name       String?
  userId     String?   @unique
  serviceId  String?
  service    Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  tickets    Ticket[]
  breaks     TellerBreak[]
}

enum TicketStatus {
  waiting
  called
  serving
  held
  completed
  no_show
}

model Ticket {
  id               String         @id @default(cuid())
  ticketDay        String         // YYYY-MM-DD so numbers reset per day
  ticketNumber     String         // A01..A99, B01..B99, etc. unique per day per branch
  queueLabel       String         // service name
  phoneNumber      String?
  branchId         String?
  branch           Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  status           TicketStatus   @default(waiting)
  callCount        Int            @default(0)
  calledAt         DateTime?
  completedAt      DateTime?
  servedByTellerId String?
  servedByTeller   Teller?        @relation(fields: [servedByTellerId], references: [id])
  createdAt        DateTime       @default(now())
  transactions     TicketTransaction[]

  @@unique([ticketDay, ticketNumber, branchId])
}

model TicketTransaction {
  id         String    @id @default(cuid())
  ticketId   String
  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  label      String
  completedAt DateTime?
}

/** Break intervals for a teller (endedAt null = break in progress). */
model TellerBreak {
  id        String    @id @default(cuid())
  tellerId  String
  teller    Teller    @relation(fields: [tellerId], references: [id], onDelete: Cascade)
  startedAt DateTime  @default(now())
  endedAt   DateTime?
}

model AppSettings {
  id                String   @id @default(cuid())
  apiKey            String?
  apiUrl            String?
  adminUsername     String?
  adminPasswordHash String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
