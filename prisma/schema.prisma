// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  services  Service[]
  tellers   Teller[]
}

model Service {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
}

model Teller {
  id         String    @id @default(cuid())
  tillNumber Int       @unique
  pinHash    String?
  name       String?
  userId     String?   @unique
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  tickets    Ticket[]
  breaks     TellerBreak[]
}

enum TicketStatus {
  waiting
  called
  serving
  held
  completed
  no_show
}

model Ticket {
  id               String         @id @default(cuid())
  ticketDay        String         // YYYY-MM-DD so numbers reset per day
  ticketNumber     String         // A01..A99, B01..B99, etc. unique per day
  queueLabel       String         // "Category Name - Service Name"
  @@unique([ticketDay, ticketNumber])
  status           TicketStatus   @default(waiting)
  callCount        Int            @default(0)
  calledAt         DateTime?
  completedAt      DateTime?
  servedByTellerId String?
  servedByTeller   Teller?        @relation(fields: [servedByTellerId], references: [id])
  createdAt        DateTime       @default(now())
  transactions     TicketTransaction[]
}

model TicketTransaction {
  id         String    @id @default(cuid())
  ticketId   String
  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  label      String
  completedAt DateTime?
}

/** Break intervals for a teller (endedAt null = break in progress). */
model TellerBreak {
  id        String    @id @default(cuid())
  tellerId  String
  teller    Teller    @relation(fields: [tellerId], references: [id], onDelete: Cascade)
  startedAt DateTime  @default(now())
  endedAt   DateTime?
}

model AppSettings {
  id                String   @id @default(cuid())
  apiKey            String?
  apiUrl            String?
  adminUsername     String?
  adminPasswordHash String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
